# Django backend environment variables
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun. `.env` git'e commit edilmemelidir.

# `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"` ile üretin
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret

# Production'da False olmalı
DJANGO_DEBUG=True

# Virgülle ayrılmış host listesi
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Virgülle ayrılmış izinli origin'ler (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
